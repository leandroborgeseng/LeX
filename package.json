{
  "name": "lex-finance",
  "private": true,
  "packageManager": "pnpm@9.14.2",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"pnpm --filter @lex/api dev\" \"pnpm --filter @lex/web dev\"",
    "build": "pnpm --filter @lex/web build && pnpm --filter @lex/api build",
    "start": "pnpm --filter @lex/api start:prod",
    "docker:build": "docker build -t lex-finance .",
    "docker:up": "docker compose up --build",
    "docker:run": "docker run --rm -p 3000:3000 -e JWT_SECRET=dev-docker -e LEX_SEED_PASSWORD=lex-docker-seed -v lex_sqlite:/data lex-finance",
    "db:generate": "pnpm --filter @lex/api prisma generate",
    "db:push": "pnpm --filter @lex/api prisma db push",
    "db:migrate": "pnpm --filter @lex/api prisma migrate deploy",
    "db:seed": "pnpm --filter @lex/api prisma db seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
